{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["styled-components-react-native"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "styled-components.d.ts"
  ],
  "exclude": ["**/node_modules", "**/Pods"]
}
